# ───────────────────────────────────────────────────────────────
# ARIA configuration
#
# Copy this file to  aria/backend/.env  and fill in the values you need.
#   cp aria/.env.example aria/backend/.env
#
# Leave it as-is (or empty) to run in demo mode with zero credentials.
# Set ARIA_MODE=live + the keys below to pull real data via MCP.
# ───────────────────────────────────────────────────────────────

# Run mode: "demo" (synthetic signals) or "live" (real MCP servers)
ARIA_MODE=demo

# ── Gemini brain ────────────────────────────────────────────────
# Get a Gemini API key (free tier available):
#   https://aistudio.google.com/apikey
# If GOOGLE_API_KEY is set, ARIA reasons with real Gemini.
# If unset in demo mode, ARIA uses a scripted reasoning trace.
GOOGLE_API_KEY=
# Model id (hackathon requires Gemini 3). Override if the preview id changes.
ARIA_MODEL=gemini-3-pro-preview

# Alternative: route through Vertex AI instead of the Gemini API.
#   Enable the Vertex AI API:  https://console.cloud.google.com/apis/library/aiplatform.googleapis.com
#   Auth locally with:         gcloud auth application-default login
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global

# ── Arize Phoenix MCP (AI observability) ────────────────────────
# Used only when ARIA_MODE=live.
# Sign in to Phoenix Cloud, then: Settings → API Keys
#   https://app.phoenix.arize.com           (hosted Phoenix)
#   API keys & host docs: https://arize.com/docs/phoenix/settings/api-keys
# If you self-host Phoenix, set PHOENIX_HOST to your own URL.
PHOENIX_HOST=https://app.phoenix.arize.com
PHOENIX_API_KEY=
PHOENIX_PROJECT=default

# ── Dynatrace MCP (infra observability) ─────────────────────────
# Used only when ARIA_MODE=live.
# DT_ENVIRONMENT: your platform URL, e.g. https://abc12345.apps.dynatrace.com
#   (do NOT use the classic *.live.dynatrace.com URL)
# DT_PLATFORM_TOKEN: create a Platform Token in Dynatrace:
#   Account/menu → Access Tokens → Platform tokens, OR see:
#   https://docs.dynatrace.com/docs/manage/identity-access-management/access-tokens-and-oauth-clients/platform-tokens
# Required token scopes (minimum to read data):
#   app-engine:apps:run, storage:buckets:read, storage:logs:read,
#   storage:metrics:read, storage:events:read, storage:spans:read
# (For send_slack_message / send_event also add the matching write scopes.)
DT_ENVIRONMENT=
DT_PLATFORM_TOKEN=
# Optional: Slack connection id for send_slack_message
#   https://docs.dynatrace.com/docs/analyze-explore-automate/workflows/actions/slack
SLACK_CONNECTION_ID=

# ── Server ──────────────────────────────────────────────────────
ARIA_HOST=0.0.0.0
ARIA_PORT=8000
# Comma-separated allowed CORS origins for the frontend
ARIA_CORS_ORIGINS=http://localhost:3000
